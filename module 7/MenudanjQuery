<!DOCTYPE html>
<html>
<head>
  <title>Menu jQuery</title>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <style>
    body { font-family: Arial; margin: 0; }
    nav ul { list-style: none; margin: 0; padding: 0;
             background: #2c3e50; display: flex; }
    nav ul li { position: relative; }
    nav ul li a { display: block; padding: 15px 20px;
                  color: white; text-decoration: none; }
    nav ul li a:hover { background: #3498db; }
    /* Submenu */
    nav ul li ul { display: none; position: absolute;
                   top: 100%; left: 0; background: #34495e;
                   min-width: 150px; z-index: 999; }
    nav ul li ul li a { padding: 10px 20px; }
  </style>
</head>
<body>
  <nav>
    <ul id="menu">
      <li><a href="#">Beranda</a></li>
      <li>
        <a href="#">Produk ▾</a>
        <ul>
          <li><a href="#">Laptop</a></li>
          <li><a href="#">Handphone</a></li>
          <li><a href="#">Tablet</a></li>
        </ul>
      </li>
      <li>
        <a href="#">Layanan ▾</a>
        <ul>
          <li><a href="#">Konsultasi</a></li>
          <li><a href="#">Dukungan</a></li>
        </ul>
      </li>
      <li><a href="#">Kontak</a></li>
    </ul>
  </nav>

  <script>
    $(document).ready(function() {
      // Tampilkan submenu saat hover
      $("#menu li").hover(
        function() { $(this).children("ul").slideDown(200); },
        function() { $(this).children("ul").slideUp(200); }
      );
    });
  </script>
</body>
</html>